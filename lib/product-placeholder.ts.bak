/**
 * 产品图片系统
 * 优先使用Unsplash产品图 → 生成的图片映射 → 品类SVG产品轮廓
 */

let _imageMap: Record<string, string> = {}

export function setProductImageMap(map: Record<string, string>) {
  _imageMap = map
}


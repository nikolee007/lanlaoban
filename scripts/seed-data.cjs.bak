function getReviewPool(productName, supplierTags) {
  const allTags = supplierTags ? supplierTags.join(' ') + ' ' + productName : productName;
  if (/耳机|音箱|音质|蓝牙|充电|数据线|手机|智能|电子|数码/i.test(allTags)) return reviewContentPools.electronics;
  if (/服装|衣服|女装|男装|童装|内衣|运动服|瑜伽|连衣裙|T恤|衬衫/i.test(allTags)) return reviewContentPools.clothing;
  if (/沙发|家具|茶几|床垫|桌|椅|柜|家居/i.test(allTags)) return reviewContentPools.homeFurniture;
  if (/日用|收纳|厨房|保温|硅胶|塑料|清洁/i.test(allTags)) return reviewContentPools.dailyGoods;
  if (/鞋|运动鞋|拖鞋|凉鞋|跑鞋/i.test(allTags)) return reviewContentPools.shoes;
  if (/食品|海鲜|虾|鱼肉|调味|酱料|零食|茶叶|饮料/i.test(allTags)) return reviewContentPools.food;
  if (/玩具|积木|盲盒|公仔|潮玩|遥控/i.test(allTags)) return reviewContentPools.toys;
  if (/美妆|护肤|化妆品|面膜|洗面奶|口红/i.test(allTags)) return reviewContentPools.beauty;
  return reviewContentPools.general;
}

function pickRandom(arr) {
  return arr[Math.floor(Math.random() * arr.length)];
}

function pickRandomN(arr, n) {
  const shuffled = [...arr].sort(() => Math.random() - 0.5);
  return shuffled.slice(0, n);
}

function generateReviews(targetId, targetType, productRating, productName, supplierTags) {
  const count = 3 + Math.floor(Math.random() * 6); // 3-8
  const pool = getReviewPool(productName, supplierTags);
  const results = [];

  for (let i = 0; i < count; i++) {
    const platform = pickRandom(platforms);
    const rating = Math.min(5, Math.max(1, +(productRating + (Math.random() - 0.5) * 1.2).toFixed(1)));
    const name = pickRandom(chineseNames);
    const reviewTexts = pickRandomN(pool, 2 + Math.floor(Math.random() * 3));

    // Build keywords that embed username + content for realistic feel
    const keywords = reviewTexts.map(t => `${name}: ${t}`);
    // Add one more review-like keyword from a different perspective
    const secondName = pickRandom(chineseNames.filter(n => n !== name));
    const extraText = pickRandom(pool);
    keywords.push(`${secondName}: ${extraText}`);

    results.push({
      targetId,
      targetType,
      platform,
      rating,
      reviewCount: Math.floor(30 + Math.random() * 500),
      returnRate: +(Math.random() * 5 + 0.5).toFixed(1),
      repurchaseRate: +(Math.random() * 35 + 10).toFixed(1),
      keywords: JSON.stringify(keywords),
      collectedAt: new Date(Date.now() - Math.floor(Math.random() * 60 * 86400000)),
    });
  }

  return results;
}

